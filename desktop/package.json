{
  "name": "paw-hub",
  "version": "4.0.5",
  "description": "PAW Hub — Your AI Agent OS for Desktop",
  "author": {
    "name": "Dosuka",
    "email": "dosukasol@users.noreply.github.com"
  },
  "homepage": "https://github.com/DosukaSOL/paw-agents",
  "repository": {
    "type": "git",
    "url": "https://github.com/DosukaSOL/paw-agents.git"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && electron dist/main.js",
    "dev": "tsc && electron dist/main.js",
    "clean": "node -e \"const fs=require('fs');['dist/mac-arm64','dist/win-unpacked','dist/win-arm64-unpacked','dist/linux-unpacked','dist/builder-debug.yml'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(_){}})\"",
    "prepackage": "npm run clean && npm run build",
    "package:mac": "npm run prepackage && electron-builder --mac",
    "package:win": "npm run prepackage && electron-builder --win",
    "package:linux": "npm run prepackage && electron-builder --linux"
  },
  "build": {
    "appId": "ai.pawagents.desktop",
    "productName": "PAW Agents",
    "icon": "icon.png",
    "afterPack": "./afterPack.js",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "maintainer": "Dosuka <dosukasol@users.noreply.github.com>",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "files": [
      "dist/**/*.js",
      "!dist/**/mac-*/**",
      "!dist/**/win-*/**",
      "!dist/**/linux-*/**",
      "!dist/builder-debug.yml",
      "!dist/**/*.blockmap",
      "!dist/**/*.dmg",
      "!dist/**/*.zip",
      "!dist/**/*.exe",
      "!dist/**/*.AppImage",
      "!dist/**/*.deb",
      "renderer/**/*",
      "icon.png",
      "build/**/*"
    ]
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.6.0"
  }
}
