{
  "name": "paw-hub",
  "version": "3.4.0",
  "description": "PAW Hub — Your AI Agent OS for Desktop",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "electron dist/main.js",
    "dev": "tsc && electron dist/main.js",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "ai.pawagents.desktop",
    "productName": "PAW Agents",
    "icon": "icon.png",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    },
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "icon.png",
      "build/**/*"
    ]
  },
  "dependencies": {
    "electron": "^33.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0"
  }
}
