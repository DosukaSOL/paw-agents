{
  "name": "paw-hub",
  "version": "4.0.1",
  "description": "PAW Hub — Your AI Agent OS for Desktop",
  "author": {
    "name": "Dosuka",
    "email": "dosukasol@users.noreply.github.com"
  },
  "homepage": "https://github.com/DosukaSOL/paw-agents",
  "repository": {
    "type": "git",
    "url": "https://github.com/DosukaSOL/paw-agents.git"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && electron dist/main.js",
    "dev": "tsc && electron dist/main.js",
    "package:mac": "tsc && electron-builder --mac",
    "package:win": "tsc && electron-builder --win",
    "package:linux": "tsc && electron-builder --linux"
  },
  "build": {
    "appId": "ai.pawagents.desktop",
    "productName": "PAW Agents",
    "icon": "icon.png",
    "afterPack": "./afterPack.js",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "maintainer": "Dosuka <dosukasol@users.noreply.github.com>",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "icon.png",
      "build/**/*"
    ]
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.6.0"
  }
}
