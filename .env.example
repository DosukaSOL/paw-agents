# ─── PAW Agents v3.4 Configuration ───

# ─── Agent Mode ───
# supervised = all risky actions require confirmation (default)
# autonomous = only critical risks require confirmation
# free = limited free tier with safety guardrails
AGENT_MODE=supervised
REQUIRE_VALIDATION=true
CONFIRM_HIGH_RISK=true
MAX_HISTORY_LENGTH=50
THINKING_LEVEL=medium

# ─── Telegram ───
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── Discord (optional) ───
DISCORD_BOT_TOKEN=

# ─── Slack (optional) ───
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ─── WhatsApp (optional) ───
WHATSAPP_SESSION_PATH=./data/whatsapp

# ─── Gateway ───
GATEWAY_PORT=18789
GATEWAY_HOST=127.0.0.1
GATEWAY_AUTH_TOKEN=
GATEWAY_CORS_ORIGINS=*

# ─── AI Models ───
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemma-3-27b-it
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
DEFAULT_MODEL_PROVIDER=openai
DEFAULT_MODEL_NAME=gpt-4o

# ─── Ollama (Local AI — FREE, no API key needed) ───
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4

# ─── Solana ───
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WALLET_ENCRYPTION_KEY=generate_a_32_byte_hex_key_here
SOLANA_NETWORK=mainnet-beta

# ─── Purp SCL ───
PURP_COMPILER_PATH=
PURP_PROJECT_DIR=./purp
PURP_AUTO_COMPILE=true

# ─── Security ───
MAX_TRANSACTION_LAMPORTS=1000000000
REQUIRE_CONFIRMATION_ABOVE_SOL=1.0
RATE_LIMIT_PER_MINUTE=30
SANDBOX_MODE=strict

# ─── Multi-Tenant (v3.4) ───
MULTI_TENANT_ENABLED=false
TENANT_ISOLATION=strict
MAX_TENANTS=100

# ─── OAuth2 / SSO (v3.4) ───
OAUTH2_ENABLED=false
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_ISSUER_URL=
SESSION_SECRET=generate_a_random_64_char_string

# ─── Cron ───
CRON_ENABLED=true
CRON_MAX_TASKS=50

# ─── Clawtrace ───
CLAWTRACE_LOG_DIR=./logs/clawtrace
CLAWTRACE_RETENTION_DAYS=90

# ─── Environment ───
NODE_ENV=production
LOG_LEVEL=info
