# ─── PAW Agents Configuration ───

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Models
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Default model (openai | anthropic)
DEFAULT_MODEL_PROVIDER=openai
DEFAULT_MODEL_NAME=gpt-4o

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WALLET_ENCRYPTION_KEY=generate_a_32_byte_hex_key_here

# Security
MAX_TRANSACTION_LAMPORTS=1000000000
REQUIRE_CONFIRMATION_ABOVE_SOL=1.0
RATE_LIMIT_PER_MINUTE=30

# Clawtrace
CLAWTRACE_LOG_DIR=./logs/clawtrace
CLAWTRACE_RETENTION_DAYS=90

# Environment
NODE_ENV=production
LOG_LEVEL=info
